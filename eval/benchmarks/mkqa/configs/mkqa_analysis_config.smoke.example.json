{
  "runtime": {
    "output_root": "eval_results/mkqa/smoke/mixed",
    "device": "cuda",
    "dtype": "auto",
    "max_length": 512,
    "max_examples": 8,
    "default_max_new_tokens": 16
  },
  "shared": {
    "data_path": "eval/benchmarks/mkqa/data/mkqa_da_en_subset.json",
    "model_root": "__MODEL_ROOT__",
    "model_registry": "model_paths/all_models.txt",
    "model_catalog": "model_paths/models.json",
    "tokenizer_path": null,
    "languages": [
      "en",
      "da"
    ],
    "public_expert_idx": 0,
    "routing_run_mode": "native_only",
    "combined_active_experts": "2,4,7",
    "include_individual_experts": false,
    "capture_router_tensors": true,
    "capture_hidden_states": false,
    "hidden_state_layers": [
      0,
      -1
    ],
    "capture_output_token_ids": true,
    "vocab_sources": "prompt,predicted,ground_truth",
    "top_tokens": 20
  },
  "models": [
    {
      "enabled": true,
      "model_name": "Flex-code-2x7B-1T"
    },
    {
      "enabled": true,
      "model_name": "Flex-danish-2x7B-55B-v2"
    },
    {
      "enabled": true,
      "model_name": "FlexOlmo-8x7B-1T-a2-55B-v2"
    },
    {
      "enabled": true,
      "model_name": "FlexOlmo-8x7B-1T-a4-55B-v2"
    },
    {
      "enabled": true,
      "model_name": "FlexOlmo-8x7B-1T-a7-55B-v2"
    }
  ],
  "analyses": {
    "routing": {
      "enabled": true
    },
    "vocab_specialization": {
      "enabled": true
    },
    "domain_specialization": {
      "enabled": true
    }
  }
}
