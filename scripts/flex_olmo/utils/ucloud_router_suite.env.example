# Copy this file and fill in the remote values before launching.

UCLOUD_HOST=your.ucloud.host
UCLOUD_PORT=22
UCLOUD_USER=your_username

# Optional: activate your venv/conda env before running the remote script.
REMOTE_ENV_ACTIVATE=/path/to/venv/bin/activate

# Optional: set if the remote eval script should run from a specific repo directory.
REMOTE_WORKDIR=/path/to/flex-moe-toolkit

# This can point either to the eval script in this repo or to another eval pipeline path on UCloud.
REMOTE_EVAL_SCRIPT=/path/to/flex-moe-toolkit/scripts/flex_olmo/utils/evaluate_flex_olmo_model_suite.py
REMOTE_PYTHON_BIN=python3

REMOTE_OUTPUT_ROOT=/path/to/outputs/flex_olmo/router_suite
REMOTE_SUMMARY_JSONL=/path/to/outputs/flex_olmo/router_suite/router_suite_summary.jsonl

REMOTE_DEVICE=cuda
REMOTE_DTYPE=auto
REMOTE_MAX_LENGTH=1024
# REMOTE_MAX_EXAMPLES=32

# Optional if tokenizer is shared across runs; otherwise each model path is used as its own tokenizer path.
# REMOTE_TOKENIZER_PATH=/path/to/tokenizer

# Choose one of these input styles:
# 1. Point to local text files with one remote path per line
MODEL_LIST_FILE=scripts/flex_olmo/utils/ucloud_models.txt
DATASET_LIST_FILE=scripts/flex_olmo/utils/ucloud_datasets.txt

# 2. Or inline comma-separated remote paths directly in this file
# MODEL_PATHS=/remote/model_a2_5B,/remote/model_a4_v1_10B
# DATASET_PATHS=/remote/eval/math.jsonl,/remote/eval/reasoning.jsonl
